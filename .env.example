# Smart Campus - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/smart_campus?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=campus_user
SPRING_DATASOURCE_PASSWORD=campus_pass
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA/Hibernate Configuration
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Server Configuration
SERVER_PORT=8081
FRONTEND_PORT=5173

# OAuth2 Google Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8081/login/oauth2/code/google

# OAuth2 Frontend URLs
OAUTH2_FRONTEND_SUCCESS_URL=http://localhost:5173/login
OAUTH2_FRONTEND_FAILURE_URL=http://localhost:5173/login?error=true

# Admin Credentials (Change in production!)
ADMIN_NAME=admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@1

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# JWT Configuration (if applicable)
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRATION=86400000

# File Upload Configuration
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Application Profile
APP_PROFILE=development
